/* 282 */ IDENTIFIER: /[a-zA-Z_][a-zA-Z0-9_]*/;
/* 283 */ ASSIGNMENT: ':=';
/* 284 */ COLON: ':';
/* 285 */ COMMA: ',';
/* 286 */ DOTDOT: '..';
