/* 244 */ AND: /(?i)AND(?-i)/;
/* 245 */ ARRAY: /(?i)ARRAY(?-i)/;
/* 246 */ PBEGIN: /(?i)BEGIN(?-i)/;
/* 247 */ CASE: /(?i)CASE(?-i)/;
